#!/bin/bash
# /app/docker - Deploy buyrunplace/webwebwebweb8888 image to create 3 apps

set -e

echo "========================================="
echo "  Deploying Docker Image to Clever Cloud"
echo "========================================="
echo ""

DOCKER_IMAGE="buyrunplace/webwebwebweb8888"
APP_COUNT=3

echo "🐳 Docker Image: $DOCKER_IMAGE"
echo "📦 Number of apps: $APP_COUNT"
echo ""

# Login to Clever Cloud
echo "🔐 Logging into Clever Cloud..."
clever login
echo ""

# Deploy 3 apps using the Docker image
for i in $(seq 1 $APP_COUNT); do
    echo "========================================="
    echo "  Deploying App $i of $APP_COUNT"
    echo "========================================="
    
    # Generate unique app name
    APP_NAME="webapp-$(date +%s)-${RANDOM}"
    
    echo "📱 App Name: $APP_NAME"
    echo "🐳 Image: $DOCKER_IMAGE"
    echo ""
    
    # Create app with Docker image
    echo "Creating app from Docker image..."
    clever create --type docker --image "$DOCKER_IMAGE" "$APP_NAME"
    
    echo ""
    echo "Deploying app..."
    clever deploy --app "$APP_NAME" --force
    
    echo ""
    echo "✅ App $i deployed successfully!"
    echo "🔗 URL: https://$APP_NAME.osc-fr1.scalingo.io"
    echo ""
    
    # Wait between deployments
    if [ $i -lt $APP_COUNT ]; then
        echo "⏳ Waiting 15 seconds before next deployment..."
        sleep 15
        echo ""
    fi
done

echo "========================================="
echo "  🎉 All $APP_COUNT apps deployed successfully! 🎉"
echo "========================================="
echo ""
echo "Deployed Apps:"
clever apps | grep "webapp-" || echo "Check your Clever Cloud dashboard"
echo ""
