#!/bin/bash
# /app/docker - Deploy 3 apps using buyrunplace/webwebwebweb8888 image

set -e

echo "===== Deploying 3 Apps with buyrunplace/webwebwebweb8888 ====="

# Check if clever is available
if ! command -v clever &> /dev/null; then
    echo "ERROR: clever command not found"
    echo "Installing clever-tools..."
    npm install -g clever-tools
fi

# Check token
if [ -z "$CLEVER_TOKEN" ]; then
    echo "ERROR: CLEVER_TOKEN environment variable not set"
    exit 1
fi

# Login to Clever Cloud
echo "Logging into Clever Cloud..."
clever login --token "$CLEVER_TOKEN"

# Configuration
IMAGE_NAME="buyrunplace/webwebwebweb8888"
APP_COUNT=3

echo "Image: $IMAGE_NAME"
echo "Number of apps: $APP_COUNT"

# Function to generate random name
generate_name() {
    cat /dev/urandom | tr -dc 'a-z0-9' | fold -w 10 | head -n 1
}

# Deploy apps
for ((i=1; i<=$APP_COUNT; i++)); do
    echo ""
    echo "========================================="
    echo "Deploying app $i of $APP_COUNT"
    echo "========================================="
    
    # Generate unique app name
    APP_NAME="webapp-$(generate_name)-${i}"
    
    echo "App name: $APP_NAME"
    echo "Image: $IMAGE_NAME"
    
    # Create app with Docker image
    clever create --type docker --image "$IMAGE_NAME" "$APP_NAME"
    
    # Set environment variables
    clever env set APP_NUMBER "$i" --app "$APP_NAME"
    clever env set DEPLOY_TIME "$(date)" --app "$APP_NAME"
    clever env set DEPLOY_TYPE "buyrunplace" --app "$APP_NAME"
    
    # Deploy
    echo "Deploying $APP_NAME..."
    clever deploy --app "$APP_NAME" --force
    
    # Get the app URL
    APP_URL="https://$APP_NAME.osc-fr1.scalingo.io"
    echo "✅ App $i deployed: $APP_URL"
    
    # Wait between deployments
    if [ $i -lt $APP_COUNT ]; then
        echo "Waiting 15 seconds before next deployment..."
        sleep 15
    fi
done

echo ""
echo "========================================="
echo "✅ All 3 apps deployed successfully!"
echo "========================================="
echo ""
echo "Deployed apps:"
clever apps | grep "webapp-" || echo "Check Clever Cloud dashboard"

exit 0
