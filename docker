#!/bin/bash
# /app/docker - Fixed deployment script

set -e

echo "===== Starting Deployment Process ====="

# Use /app directory instead of root
WORK_DIR="/app"
cd "$WORK_DIR" || exit 1

# Get parameters
IMAGE_NAME="${1:-webwebwebweb8888}"
START_CMD="${2:-start}"
DEPLOY_TYPE="${3:-buyrunplace}"
INSTANCE_ID="${4:-INSTANCE_1}"
APP_COUNT="${5:-3}"

echo "Parameters:"
echo "  Image Name: $IMAGE_NAME"
echo "  Start Command: $START_CMD"
echo "  Deploy Type: $DEPLOY_TYPE"
echo "  Instance ID: $INSTANCE_ID"
echo "  App Count: $APP_COUNT"
echo ""

# Create necessary directories
mkdir -p "$WORK_DIR/temp"
mkdir -p "$WORK_DIR/clever8874"
mkdir -p "$WORK_DIR/linux8888"

# Create default Dockerfile template if not exists
if [ ! -f "$WORK_DIR/clever8874/Dockerfile8888" ]; then
    cat > "$WORK_DIR/clever8874/Dockerfile8888" << 'EOF'
FROM thetradeboxsignal88888888:latest
RUN apt-get update && apt-get install -y curl wget git
CMD ["start"]
ENV DEPLOY_TYPE=tradeinc
EOF
    echo "Created default Dockerfile template"
fi

# Create linux8888 helper script if not exists
if [ ! -f "$WORK_DIR/linux8888" ]; then
    cat > "$WORK_DIR/linux8888" << 'EOF'
#!/bin/bash
linuxweb8888="$1"

echo "Running linux8888 script with name: $linuxweb8888"

cd /app || exit 1

# Configure git
git config --global user.email "$linuxweb8888@gmail.com"
git config --global user.name "$linuxweb8888"

# Commit changes
git commit -m "$linuxweb8888" 2>/dev/null || echo "No changes to commit"

# Clever Cloud operations
echo "Creating Clever Cloud app: $linuxweb8888"
clever create --type docker "$linuxweb8888" 2>/dev/null || echo "App may already exist"

echo "Scaling app: $linuxweb8888"
clever scale --instances 1 --alias="$linuxweb8888" 2>/dev/null || true

echo "Deploying app: $linuxweb8888"
clever deploy --alias="$linuxweb8888" --force

echo "Completed linux8888 script for $linuxweb8888"
EOF
    chmod +x "$WORK_DIR/linux8888"
    echo "Created linux8888 helper script"
fi

# Check if clever is available
if ! command -v clever &> /dev/null; then
    echo "Installing clever-tools..."
    npm install -g clever-tools@latest
fi

# Check clever version
echo "Clever version: $(clever --version 2>/dev/null || echo 'Unknown')"

# Login to Clever Cloud (will show URL for OAuth)
echo "Please login to Clever Cloud..."
echo "AUTH_URL_START"
clever login
echo "AUTH_URL_END"

# Create multiple apps
for ((n=0; n<$APP_COUNT; n++)); do
    echo ""
    echo "========================================="
    echo "Creating app $((n+1)) of $APP_COUNT"
    echo "========================================="
    
    # Generate random names
    linuxlinux8888="$(cat /dev/urandom | tr -dc 'a-z0-9' | fold -w 16 | head -n 1)"
    webwebwebweb8888="$(cat /dev/urandom | tr -dc 'a-z0-9' | fold -w 16 | head -n 1)"
    linux8888="$(shuf -i8888-88888888 -n1)"
    
    echo "Generated names:"
    echo "  linuxlinux8888: $linuxlinux8888"
    echo "  webwebwebweb8888: $webwebwebweb8888"
    echo "  linux8888: $linux8888"
    
    # Create directory in /app/temp
    APP_DIR="$WORK_DIR/temp/$linux8888"
    mkdir -p "$APP_DIR"
    echo "Created directory: $APP_DIR"
    
    # Copy Dockerfile
    cp "$WORK_DIR/clever8874/Dockerfile8888" "$APP_DIR/Dockerfile"
    echo "Copied Dockerfile to $APP_DIR/Dockerfile"
    
    # Modify Dockerfile with sed
    sed -i "s/thetradeboxsignal88888888/${IMAGE_NAME}/g" "$APP_DIR/Dockerfile"
    sed -i "s/start/${START_CMD}/g" "$APP_DIR/Dockerfile"
    sed -i "s/tradeinc/${DEPLOY_TYPE}/g" "$APP_DIR/Dockerfile"
    
    echo "Dockerfile modified with:"
    echo "  Image: $IMAGE_NAME"
    echo "  Start: $START_CMD"
    echo "  Type: $DEPLOY_TYPE"
    
    # Show Dockerfile content for debugging
    echo "Dockerfile content:"
    cat "$APP_DIR/Dockerfile"
    
    # Initialize git in the app directory
    cd "$APP_DIR"
    git init
    git add .
    git commit -m "Initial commit for $linuxlinux8888" || echo "Nothing to commit"
    
    # Run the linux8888 script in background
    echo "Running linux8888 script with name: $linuxlinux8888"
    bash "$WORK_DIR/linux8888" "$linuxlinux8888" &
    
    echo "linux8888"
    sleep 10
done

echo ""
echo "========================================="
echo "✅ All applications deployed successfully!"
echo "========================================="

sleep 80
