#!/bin/bash
# /app/docker - Create 3 apps on Clever Cloud

set -e

echo "========================================="
echo "  Deploying 3 Apps to Clever Cloud"
echo "========================================="

WORK_DIR="/app"
cd "$WORK_DIR" || exit 1

# Create Dockerfile
cat > "$WORK_DIR/Dockerfile" << 'EOF'
FROM buyrunplace/webwebwebweb8888
CMD cd /bot8888/; bash ./start & service apache2 start & while true; do sleep 14000; done
EOF

echo "✅ Dockerfile created"

# Check if clever is installed
if ! command -v clever &> /dev/null; then
    echo "Installing clever-tools..."
    npm install -g clever-tools@latest
fi

# Login to Clever Cloud (this will show OAuth URL)
echo ""
echo "🔐 Logging into Clever Cloud..."
echo "========================================="
clever login
echo "========================================="
echo ""

# Deploy 3 apps
for i in 1 2 3; do
    echo ""
    echo "========================================="
    echo "  Deploying App $i of 3"
    echo "========================================="
    
    # Generate unique app name
    RANDOM_NAME="app-$(cat /dev/urandom | tr -dc 'a-z0-9' | fold -w 10 | head -n 1)-${i}"
    
    echo "📦 App Name: $RANDOM_NAME"
    echo "🐳 Image: buyrunplace/webwebwebweb8888"
    
    # Create the app
    echo "Creating app..."
    clever create --type docker "$RANDOM_NAME"
    
    # Deploy the app
    echo "Deploying app..."
    clever deploy --app "$RANDOM_NAME" --force
    
    # Get the app URL
    APP_URL="https://$RANDOM_NAME.osc-fr1.scalingo.io"
    
    echo ""
    echo "✅ App $i deployed successfully!"
    echo "🔗 URL: $APP_URL"
    echo "========================================="
    
    # Wait between deployments
    if [ $i -lt 3 ]; then
        echo "Waiting 15 seconds before next deployment..."
        sleep 15
    fi
done

echo ""
echo "========================================="
echo "  🎉 All 3 apps deployed successfully! 🎉"
echo "========================================="
echo ""
echo "Deployed apps:"
clever apps | grep "app-" || echo "Check your Clever Cloud dashboard"
echo ""
