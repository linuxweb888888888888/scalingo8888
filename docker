WEB8888_ENCODED=$(echo -n "$WEB8888_URL" | base64 -w 0)

# Generate random variable names (changes every run)
VAR1=$(cat /dev/urandom | tr -dc 'a-z' | fold -w 5 | head -n 1)
VAR2=$(cat /dev/urandom | tr -dc 'a-z' | fold -w 5 | head -n 1)
VAR3=$(cat /dev/urandom | tr -dc 'a-z' | fold -w 5 | head -n 1)
