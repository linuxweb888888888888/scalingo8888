{
  "name": "clever-cloud-bot",
  "version": "1.0.0",
  "description": "Clever Cloud Automation Bot with Dashboard",
  "main": "bot.js",
  "scripts": {
    "postinstall": "mkdir -p /app/bin && curl -L -o /app/bin/scalingo https://github.com/Scalingo/cli/releases/download/1.44.1/scalingo_1.44.1_linux_amd64.tar.gz && tar -xzf /app/bin/scalingo -C /app/bin/ && chmod +x /app/bin/scalingo",
    "start": "node bot.js"
  },
  "dependencies": {
    "puppeteer-core": "^21.11.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "express": "^4.18.2",
    "clever-tools": "^4.7.0",
    "https-proxy-agent": "^7.0.0",
    "socks-proxy-agent": "^8.0.0",
    "axios": "^1.6.0",
    "mongodb": "^6.3.0"
  },
  "engines": {
    "node": "20.x"
  }
}
