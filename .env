# ==================== TRADING CONFIGURATION ====================
# Trading pair (must exist on HTX futures)
SYMBOL=1000PEPE-USDT

# Total investment in USDT
TOTAL_INVESTMENT=100

# Price drop percentage to trigger next order (0.1% = 0.1)
PRICE_DECREASE_PERCENT=0.1

# Take profit percentage from average entry price (0.15% = 0.15)
TAKE_PROFIT_PERCENT=0.1

# Maximum number of safety orders (10 = 10 addition orders)
MAX_SAFETY_ORDERS=10

# Leverage (1 = no leverage, max depends on KYC level)
LEVERAGE=10

# Volume Scale multiplier (1.2x = 20% increase each order)
VOLUME_SCALE=1.2

# Initial order amount in SHIB units
INITIAL_AMOUNT=10

# ==================== SERVER CONFIGURATION ====================
# Port for the web dashboard
PORT=3000

# Auto-start bot when server launches (true/false)
AUTO_START=true
